# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# generated: prototype static site (materialized from krideus-prototype/ by
# scripts/sync-prototype.mjs on dev/build — never commit these)
/public/prototype
/public/assets
/public/airport
/public/css
/public/event
/public/includes
/public/js
/public/leisure
/public/local-trip
/public/shopping
/public/sports-shuttle
/public/support
/public/theme-park
